# Production env — external Aliyun PG + Redis.
# Copy to .env.prod, fill in values.
# Start: docker compose --env-file .env.prod -f docker-compose.prod.yml up --build -d

# External Aliyun PostgreSQL (RDS)
DATABASE_URL=postgresql://USER:PASSWORD@your-aliyun-rds-endpoint:5432/yyddp_prod

# External Aliyun Redis
REDIS_URL=redis://:PASSWORD@your-aliyun-redis-endpoint:6379

# JWT — generate a strong random secret for prod
JWT_SECRET=

# Aliyun SMS (real SMS in prod)
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN=北京自成长教育科技
ALIYUN_SMS_TEMPLATE=SMS_504055089

# Unlock engine
UNLOCK_TZ=Asia/Shanghai
UNLOCK_HOUR=10

# Aliyun OSS (yyddp-api)
OSS_ENDPOINT=https://yyddp-1228786748647400.oss-cn-beijing.oss-accesspoint.aliyuncs.com/
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Aliyun OSS (yyddp-importer)
OSS_REGION=oss-cn-beijing
OSS_IMPORTER_KEY=
OSS_IMPORTER_SECRET=
