# Environment files (all levels)
.env
.env.*
**/.env
**/.env.*
.env.example
**/.env.example
.envrc
**/.envrc
*.env
*.env.*
**/*.env
**/*.env.*
*.env.example
**/*.env.example

# Allow committed dev/prod .env templates
!.env.dev.example
!.env.prod.example
!**/.env.dev.example
!**/.env.prod.example

