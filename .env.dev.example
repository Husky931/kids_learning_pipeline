# Copy to .env.dev and fill in values. Both yyddp-api and yyddp-importer read it
# (dotenv) when started with `pnpm dev` / `pnpm run preview` from their subdirs.

# Postgres — connect to your local Postgres on localhost:5432
POSTGRES_DB=yyddp_dev
POSTGRES_USER=yyddp
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql://yyddp:devpassword@localhost:5432/yyddp_dev

# Redis — local Redis on localhost:6379
REDIS_PASSWORD=devpassword

# JWT — required. Used by yyddp-api to sign dev-only tokens.
JWT_SECRET=dev-only-jwt-secret-change-me

# Aliyun OSS (yyddp-api side) — required. Ask the operator for credentials.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Aliyun OSS (yyddp-importer side) — required. May be same as OSS_ACCESS_KEY_* above.
OSS_IMPORTER_KEY=
OSS_IMPORTER_SECRET=
